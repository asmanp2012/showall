#!/usr/bin/env bun

// showall - Main script that orchestrates all collectors
// Version: 2.1.0
// Usage: showall [command] [options] [directory]

import { $ } from "bun";
import { join, dirname, resolve } from 'path';
import { homedir } from 'os';
import { Logger } from '../lib/logger';
import { ShowallFile, showall_files_version } from '../lib/showall_file';
import { ShowallGit, showall_git_version } from '../lib/showall_git';
import { ShowallClean, showall_clean_version } from '../lib/showall_clean';

// Initialize logger
const logger = new Logger({
    logFile: join(homedir(), `.showall.log`)
});

// Script configuration
const SCRIPT_NAME = "showall";
const SCRIPT_VERSION = "2.1.0";
const SCRIPT_DIR = dirname(process.argv[1]);

// Default settings
let VERBOSE = false;
let QUIET = false;
let FORCE = false;
let OUTPUT_DIR = ".";

function titleShowall() {
    return logger.color('showall v' + SCRIPT_VERSION, 'CYAN');
}

// Show help
function showHelp() {
    console.log(`
${titleShowall()} - Complete Project Analysis Tool

${logger.color('Description:', 'GREEN')}
  Collect and analyze Git repository information and project code files.
  Clean up generated output files and temporary files.

${logger.color('Usage:', 'GREEN')}
  showall [command] [options] [directory]

${logger.color('Commands:', 'GREEN')}
  git         Collect Git repository information only
  file        Collect project code files only
  all         Run both collectors (default)
  clean       Clean up generated output files
  help        Show this help message

${logger.color('Options:', 'GREEN')}
  -f, --file              Run file collector
  -g, --git               Run git collector
  -c, --clean             Run clean command
  -m, --mode=MODE         Specify collector mode (git, file, all, clean)
  -t, --target=DIR        Target directory to analyze (default: current directory)
  -o, --output=DIR        Output directory for generated files (default: current directory)
  -v, --verbose           Enable verbose output
  -q, --quiet             Suppress non-error output
  -h, --help              Show this help message
  --version               Show version information

${logger.color('Examples:', 'GREEN')}
  # Basic usage
  showall git                    # Git info from current directory
  showall file /path/to/project  # Code from specific path
  showall all -v                  # Everything with verbose output
  showall -t=/path/to/project -o=/path/to/output  # Specify target and output
  
  # Using mode option
  showall --mode=git              # Git collector
  showall --mode=file --target=/project  # File collector with target
  
  # Clean command
  showall clean                   # Clean default patterns
  showall clean /path/to/project  # Clean in specific directory
  
  # Combined options
  showall all -t ~/projects/myapp -o ./output -v  # Analyze app with verbose output

${logger.color('Output files:', 'GREEN')}
  Git collector:     GIT_FULL_INFO_*_*.log
  File collector:    PROJECT_FULL_*.log
  Log file:          .showall.log

${logger.color('Version information:', 'GREEN')}
  Run 'showall --version' to see detailed version info for all collectors
`);
}

// Show version
function showVersion() {
    console.log(`${SCRIPT_NAME} version ${SCRIPT_VERSION}`);
    console.log(`Git collector (showall_git): ${showall_git_version}`);
    console.log(`File collector (showall_file): ${showall_files_version}`);
    console.log(`Clean collector (showall_clean): ${showall_clean_version}`);
}

// Parse command line arguments
async function parseArgs(args: string[]) {
    let i = 0;
    const positional: string[] = [];
    
    // Parse command
    let COMMAND = "file";
    let TARGET_DIR = "";
    
    const VALID_COMMANDS = [
        'git', 'file', 'all', 'clean', 'help'
    ];

    while (i < args.length) {
        const arg = args[i];
        
        // Handle commands without dash
        if (VALID_COMMANDS.includes(arg)) {
            COMMAND = arg;
            i++;
            continue;
        }
        
        let argType = arg.split('=');

        switch (argType[0]) {
            case '-h':
            case '--help':
                showHelp();
                process.exit(0);
            case '-f':
            case '--file':
                COMMAND = 'file';
                i++;
                break;

            case '-g':
            case '--git':
                COMMAND = 'git';
                i++;
                break;

            case '-c':
            case '--clean':
                COMMAND = 'clean';
                i++;
                break;
                
            case '-m':
            case '--mode':
                if(!(VALID_COMMANDS.includes(argType[1])) ) { 
                throw new Error(
                    `Invalid or missing value for --mode. Please specify one of: ${VALID_COMMANDS.join(', ')}. Example: --mode=git`
                );
                }
                COMMAND = argType[1];
                i++;
                break;

            case '-t':
            case '--target':
                if (argType[1] == null) {
                    throw new Error(`Missing value for option: '${argType[0]}'`);
                }
                
                if (!resolve(argType[1])) {
                    throw new Error(`Target directory does not exist: ${argType[1]}`);
                }
                TARGET_DIR = await $`cd "${argType[1]}" && pwd`.text();
                i++;
                break;

            case '-v':
            case '--verbose':
                VERBOSE = true;
                logger.verbose = true;
                i++;
                break;
                
            case '-q':
            case '--quiet':
                QUIET = true;
                logger.setQuiet(true);
                i++;
                break;
                
            case '-o':
            case '--output':
                if (argType[1] == null) {
                    throw new Error(`Missing value for option: '${argType[0]}'`);
                }
                
                if (!resolve(argType[1])) {
                    throw new Error(`Output directory does not exist: ${argType[1]}`);
                }
                OUTPUT_DIR = await $`cd "${argType[1]}" && pwd`.text().trim();
                i++;
                break;

            case '--version':
                showVersion();
                process.exit(0);

            default:
                if (arg.startsWith('-')) {
                    logger.error(`Unknown option: ${arg}`);
                    showHelp();
                    process.exit(1);
                }
                positional.push(arg);
                i++;
        }
    }
    
    if (TARGET_DIR == "") {
        TARGET_DIR = process.cwd();
        TARGET_DIR = await $`cd "${TARGET_DIR}" && pwd`.text();
    }
    TARGET_DIR = TARGET_DIR.trim();
    
    return { 
        COMMAND, 
        TARGET_DIR
    };
}

// Main function
async function main() {
    const args = process.argv.slice(2);
    const { COMMAND, TARGET_DIR } = await parseArgs(args);
    
    let targetPath = TARGET_DIR;
    if (targetPath) {
        if (!resolve(targetPath)) {
            logger.error(`Directory does not exist: ${targetPath}`);
            process.exit(1);
        }
    }
    
    let outputPath = OUTPUT_DIR;
    
    // Run command
    switch (COMMAND) {
        case 'help':
            showHelp();
            break;
        case 'git':
            await ShowallGit(targetPath, outputPath);
            break;
            
        case 'file':
            await ShowallFile(targetPath, outputPath);
            break;
            
        case 'all':
            logger.info('Running both collectors...');
            logger.newLine();
            
            await ShowallGit(targetPath, outputPath);
            logger.newLine();
            logger.divider('=', 50);
            logger.newLine();
            
            await ShowallFile(targetPath, outputPath);
            break;
            
        case 'clean':
            await ShowallClean(targetPath);
            break;
            
        default:
            logger.error(`Unknown command: ${COMMAND}`);
            logger.newLine();
            showHelp();
            process.exit(1);
    }
}

// Run main function
main().catch(err => {
    logger.error(`Unhandled error: ${err.message}`);
    process.exit(1);
});